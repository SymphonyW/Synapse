# Default local mode keeps the existing file-backed memory behavior.
SYNAPSE_MODEL_PROVIDER=mock
SYNAPSE_MEMORY_BACKEND=file
SYNAPSE_AGENT_MEMORY_FILE=/var/lib/synapse/agent-memory.json
SYNAPSE_AGENT_MEMORY_MAX_ENTRIES_PER_USER=80
SYNAPSE_AGENT_MEMORY_RECALL_LIMIT=3

# Enable only when you want semantic vector recall through pgvector.
# SYNAPSE_MEMORY_BACKEND=vector
# SYNAPSE_VECTOR_DATABASE_URL=postgresql://synapse:synapse@postgres:5432/synapse
# SYNAPSE_VECTOR_EMBEDDING_PROVIDER=openai_compatible
# SYNAPSE_VECTOR_EMBEDDING_MODEL=text-embedding-3-small
# SYNAPSE_VECTOR_EMBEDDING_BASE_URL=https://api.openai.com/v1
# SYNAPSE_VECTOR_EMBEDDING_API_KEY=replace-with-your-api-key
# SYNAPSE_VECTOR_EMBEDDING_DIMENSION=1536
# SYNAPSE_VECTOR_MEMORY_TOP_K=10
