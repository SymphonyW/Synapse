# Copy this file to docker-compose.gemini.env and fill your Gemini API key.
SYNAPSE_MODEL_PROVIDER=openai
SYNAPSE_OPENAI_API_KEY=replace-with-your-gemini-api-key
SYNAPSE_OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
SYNAPSE_OPENAI_MODEL=gemini-2.0-flash

# Optional tuning.
SYNAPSE_OPENAI_TEMPERATURE=0.2
SYNAPSE_OPENAI_MAX_TOKENS=512
SYNAPSE_MODEL_PROVIDER_ALIAS=gemini

SYNAPSE_OPENAI_HTTP_TIMEOUT_SECONDS=45
SYNAPSE_OPENAI_MAX_RETRIES=3
SYNAPSE_OPENAI_RETRY_BACKOFF_SECONDS=1.5
