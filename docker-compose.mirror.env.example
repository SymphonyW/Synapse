# Mirror-based image configuration to avoid Docker Hub connectivity/rate-limit issues.
# Usage:
#   docker compose --env-file docker-compose.mirror.env up --build -d

PYTHON_BASE=docker.m.daocloud.io/library/python:3.12-slim
GOLANG_BASE=docker.m.daocloud.io/library/golang:1.25
RUNTIME_BASE=docker.m.daocloud.io/library/alpine:3.20
POSTGRES_IMAGE=docker.m.daocloud.io/library/postgres:16-alpine
REDIS_IMAGE=docker.m.daocloud.io/library/redis:7-alpine
