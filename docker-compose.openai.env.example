# Copy this file to docker-compose.openai.env and fill your OpenAI API key.
SYNAPSE_MODEL_PROVIDER=openai
SYNAPSE_OPENAI_API_KEY=replace-with-your-openai-api-key
SYNAPSE_OPENAI_BASE_URL=https://api.openai.com/v1
SYNAPSE_OPENAI_MODEL=gpt-4o-mini

# Optional tuning.
SYNAPSE_OPENAI_TEMPERATURE=0.2
SYNAPSE_OPENAI_MAX_TOKENS=512

SYNAPSE_OPENAI_HTTP_TIMEOUT_SECONDS=45
SYNAPSE_OPENAI_MAX_RETRIES=3
SYNAPSE_OPENAI_RETRY_BACKOFF_SECONDS=1.5
