# Copy this file to docker-compose.zhipu.env and fill your Zhipu API key.
SYNAPSE_MODEL_PROVIDER=openai
SYNAPSE_OPENAI_API_KEY=replace-with-your-zhipu-api-key
SYNAPSE_OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
SYNAPSE_OPENAI_MODEL=glm-4-flash

# Optional tuning.
SYNAPSE_OPENAI_TEMPERATURE=0.2
SYNAPSE_OPENAI_MAX_TOKENS=512
SYNAPSE_MODEL_PROVIDER_ALIAS=zhipu

SYNAPSE_OPENAI_HTTP_TIMEOUT_SECONDS=45
SYNAPSE_OPENAI_MAX_RETRIES=3
SYNAPSE_OPENAI_RETRY_BACKOFF_SECONDS=1.5
